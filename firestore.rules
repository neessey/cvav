rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. CV-AV Members
    match /cvav_members/{memberId} {
      allow read, write: if true;
    }

    // 3. News Articles
    match /cvav_news/{newsId} {
      allow read, write: if true;
    }

    // 4. Parish Events
    match /cvav_parish/{eventId} {
      allow read, write: if true;
    }

    // 5. Memorial Gallery Items
    match /cvav_gallery/{galleryId} {
      allow read, write: if true;
    }

    // 6. Sectional Activities with enrollment rosters
    match /cvav_activities/{activityId} {
      allow read, write: if true;
    }
  }
}
